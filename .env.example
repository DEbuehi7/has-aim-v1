# ============================================================
# has-aim-v1 / Aura8 — Environment Variables Template
# Copy to .env.local for local dev, or set in Railway secrets
# ============================================================

# ------ Supabase ------
# Your Supabase project URL (public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase service-role key (private — never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Optional: Direct Postgres connection string (use PgBouncer pooler port 6543 on Railway)
DATABASE_URL=******db.your-project.supabase.co:5432/postgres

# ------ CCBill ------
# Shared secret appended to CCBill webhook URLs: /api/ccbill/webhook?secret=...
CCBILL_WEBHOOK_SECRET=your_ccbill_webhook_secret_here

# ------ Compliance Auth ------
# 32-byte hex secret for signing compliance session tokens
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COMPLIANCE_SESSION_SECRET=your_64_char_hex_secret_here

# Session duration in minutes (default 30)
COMPLIANCE_SESSION_DURATION_MINUTES=30

# Optional: Comma-separated IP allowlist for compliance dashboard
# COMPLIANCE_IP_WHITELIST=203.0.113.0,198.51.100.0

# ------ Admin Debug ------
# Secret required to access /admin/ccbill?secret=...
ADMIN_DEBUG_SECRET=your_admin_debug_secret_here

# ------ Site URL ------
NEXT_PUBLIC_SITE_URL=https://aura8.fun

# ------ Email (SendGrid) ------
SENDGRID_API_KEY=SG.your_sendgrid_key_here

# Email verification token expiry in minutes
EMAIL_VERIFICATION_TOKEN_EXPIRY_MINUTES=10

# ------ Twilio (optional SMS) ------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ------ BatchData (optional) ------
BATCHDATA_API_KEY=your_batchdata_api_key_here
